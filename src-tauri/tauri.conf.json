{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Omniterm",
  "version": "0.1.8",
  "identifier": "com.omniterm.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5174",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Omniterm",
        "width": 1200,
        "height": 760,
        "minWidth": 800,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": false,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "Entitlements.plist",
      "bundleName": "Omniterm"
    },
    "windows": {
      "wix": {
        "language": [
          "en-US"
        ]
      }
    }
  }
}
